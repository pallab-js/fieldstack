# Fieldstack - Development Environment Variables
# Copy this file to .env and fill in your values.
# These are used ONLY during development. Production builds embed config via tauri.conf.json.

# ---- Frontend (Vite) ----
# Development server port (default: 1420)
VITE_PORT=1420
# HMR WebSocket port (default: 1421)
VITE_HMR_PORT=1421

# ---- Tauri (Rust backend) ----
# Log level for development: trace | debug | info | warn | error
RUST_LOG=debug

# ---- Code Signing (CI only, not needed for local dev) ----
# APPLE_CERTIFICATE=<base64-encoded p12 certificate>
# APPLE_CERTIFICATE_PASSWORD=<certificate password>
# APPLE_SIGNING_IDENTITY=<signing identity name>
# APPLE_ID=<apple developer email>
# APPLE_PASSWORD=<app-specific password>
# APPLE_TEAM_ID=<apple team ID>

# ---- Crash Reporting (optional, opt-in) ----
# SENTRY_DSN=<sentry data source URL>
